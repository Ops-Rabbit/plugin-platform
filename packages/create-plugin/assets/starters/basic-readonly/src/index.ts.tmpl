import { definePlugin, toolResult } from '@opsrabbit/plugin-sdk';

export const plugin = definePlugin({
  tools: [
    {
      id: 'status-summary',
      description: 'Returns a tenant-scoped status summary.',
      risk: 'read',
      audience: 'all',
      requiredPermission: 'read',
      async run(input: { service?: string }, context) {
        const service = input.service ?? 'all';
        context.logger.info('status summary requested', { service });
        return toolResult(
          `Service ${service} status is unknown for tenant ${context.tenantId}.`,
          { tenantId: context.tenantId, service, status: 'unknown' },
        );
      }
    }
  ]
});

export default plugin;
