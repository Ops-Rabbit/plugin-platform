import { definePlugin } from '@opsrabbit/plugin-sdk';

export const plugin = definePlugin({
  tools: [
    {
      id: 'save-note',
      description: 'Stores a note through the host-managed tenant record broker.',
      risk: 'write',
      audience: 'all',
      requiredPermission: 'write',
      async run(input: { id: string; text: string }, context) {
        if (!context.tenantRecords) throw new Error('Tenant record capability is unavailable');
        await context.tenantRecords.put('notes', input.id, { text: input.text });
        return { id: input.id };
      }
    }
  ]
});

export default plugin;
