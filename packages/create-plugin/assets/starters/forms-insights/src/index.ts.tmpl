      title: "Records overview",
      description: "Caller-visible record totals and category distribution.",
      suggested_questions: ["Which category has the most records?"],
      layout: { columns: 12 },
      queries: [
        {
          key: "record-count",
          dataset_id: "insights.records",
          name: "Record count",
          semantic_query: {
            dimensions: [],
