{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opsrabbit.ai/schemas/forms-analytics-catalog-v1.json",
  "title": "OpsRabbit Forms Analytics Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "metric_contract_version", "datasets"],
  "properties": {
    "schema_version": { "const": 1 },
    "metric_contract_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 40
    },
    "datasets": {
      "type": "array",
      "maxItems": 100,
      "items": { "$ref": "#/$defs/dataset" }
    }
  },
  "$defs": {
    "key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[-_][a-z0-9]+)*$"
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dataset_id",
        "label",
        "module_key",
        "record_type",
        "dimensions",
        "measures",
        "default_time_field"
      ],
      "properties": {
        "dataset_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]{0,159}$"
        },
        "label": { "type": "string", "minLength": 1, "maxLength": 160 },
        "module_key": { "$ref": "#/$defs/key" },
        "record_type": { "$ref": "#/$defs/key" },
        "parent_record_type": { "$ref": "#/$defs/key" },
        "dimensions": {
          "type": "array",
          "maxItems": 80,
          "items": { "$ref": "#/$defs/dimension" }
        },
        "measures": {
          "type": "array",
          "minItems": 1,
          "maxItems": 80,
          "items": { "$ref": "#/$defs/measure" }
        },
        "default_time_field": {
          "oneOf": [{ "$ref": "#/$defs/key" }, { "type": "null" }]
        }
      }
    },
    "dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_key", "value_type", "sensitivity"],
      "properties": {
        "field_key": { "$ref": "#/$defs/key" },
        "value_type": { "enum": ["text", "number", "boolean", "timestamp"] },
        "sensitivity": { "type": "string", "minLength": 1, "maxLength": 40 }
      }
    },
    "measure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "aggregation", "unit"],
      "properties": {
        "key": { "$ref": "#/$defs/key" },
        "aggregation": {
          "enum": ["count", "sum", "average", "sum_divide", "ratio_percent"]
        },
        "unit": { "type": "string", "minLength": 1, "maxLength": 40 },
        "field_key": { "$ref": "#/$defs/key" },
        "numerator_field_key": { "$ref": "#/$defs/key" },
        "denominator_field_key": { "$ref": "#/$defs/key" },
        "divisor": { "type": "number", "exclusiveMinimum": 0 },
        "denominator_divisor": { "type": "number", "exclusiveMinimum": 0 },
        "zero_denominator": { "const": "null" }
      }
    }
  }
}
