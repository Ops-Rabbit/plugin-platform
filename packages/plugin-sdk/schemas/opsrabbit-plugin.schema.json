{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opsrabbit.dev/schemas/plugin/v1/opsrabbit-plugin.schema.json",
  "title": "OpsRabbit Plugin Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "description",
    "apiVersion",
    "main",
    "capabilities"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$" },
    "name": { "type": "string", "minLength": 1, "maxLength": 100 },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$"
    },
    "description": { "type": "string", "minLength": 1, "maxLength": 500 },
    "apiVersion": { "const": "1.0" },
    "main": {
      "type": "string",
      "pattern": "^\\./dist/(?!.*(?:^|/)\\.\\.?/)[A-Za-z0-9._/-]+\\.js$"
    },
    "minimumOpsRabbitVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$"
    },
    "publisher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "pattern": "^https?://" }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "tools",
          "actions",
          "routes.read",
          "widgets",
          "scheduledJobs",
          "database.tenantRecords"
        ]
      }
    }
  }
}
