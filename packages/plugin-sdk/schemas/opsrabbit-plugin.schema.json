{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opsrabbit.dev/schemas/plugin/v1/opsrabbit-plugin.schema.json",
  "title": "OpsRabbit Plugin Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "description",
    "apiVersion",
    "main",
    "capabilities"
  ],
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[-_][a-z0-9]+)*$" },
    "settingKey": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$"
    },
    "risk": { "enum": ["read", "write", "destructive", "external"] },
    "role": { "enum": ["viewer", "operator", "admin"] },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "risk"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "risk": { "$ref": "#/$defs/risk" },
        "audience": { "enum": ["all", "coordinator", "general"] },
        "requiredPermission": { "enum": ["read", "use", "write", "manage"] }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "risk", "requiredRole"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "risk": { "$ref": "#/$defs/risk" },
        "requiredRole": { "$ref": "#/$defs/role" },
        "deploymentAdminOnly": { "type": "boolean" },
        "formPlacement": {
          "type": "object",
          "additionalProperties": false,
          "required": ["moduleKey", "recordType", "intent"],
          "properties": {
            "moduleKey": { "$ref": "#/$defs/settingKey" },
            "recordType": { "$ref": "#/$defs/settingKey" },
            "intent": { "enum": ["primary", "neutral", "danger"] }
          }
        }
      }
    },
    "named": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": { "id": { "$ref": "#/$defs/id" } }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "requiredRole"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^/(?!.*(?:^|/)\\.\\.?/)[A-Za-z0-9._/-]+$"
        },
        "requiredRole": { "$ref": "#/$defs/role" }
      }
    },
    "ingressRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "methods",
        "auth",
        "requiredScopes",
        "maxRequestBytes"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^/(?!.*(?:^|/)\\.\\.?/)[A-Za-z0-9._/-]+$"
        },
        "methods": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["POST", "PUT", "PATCH", "DELETE"] }
        },
        "auth": { "const": "api_token" },
        "requiredScopes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*(?:[._:-][a-z0-9]+)*$",
            "maxLength": 100
          }
        },
        "maxRequestBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1048576
        }
      }
    },
    "navigation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "moduleKey", "path", "icon", "fallbackTitle"],
      "properties": {
        "kind": { "const": "forms_workspace" },
        "moduleKey": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
        },
        "path": {
          "type": "string",
          "pattern": "^/apps/[a-z][a-z0-9_-]*$"
        },
        "icon": { "enum": ["headset", "building", "shield_check"] },
        "fallbackTitle": { "type": "string", "minLength": 1, "maxLength": 100 },
        "titleSetting": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
        },
        "iconSetting": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
        },
        "order": { "type": "number" },
        "workflow": {
          "type": "object",
          "additionalProperties": false,
          "required": ["rootStarterKey", "stageModelSetting"],
          "properties": {
            "rootStarterKey": { "$ref": "#/$defs/settingKey" },
            "stageModelSetting": { "$ref": "#/$defs/settingKey" },
            "recordNumber": {
              "type": "object",
              "additionalProperties": false,
              "required": ["prefixSetting", "digitsSetting"],
              "properties": {
                "prefixSetting": { "$ref": "#/$defs/settingKey" },
                "digitsSetting": { "$ref": "#/$defs/settingKey" }
              }
            }
          }
        }
      }
    },
    "formStarterPack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["moduleKey", "path"],
      "properties": {
        "moduleKey": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
        },
        "path": {
          "type": "string",
          "pattern": "^\\./forms/[a-z][a-z0-9_-]*\\.json$"
        }
      }
    },
    "setting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "type"],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
        },
        "label": { "type": "string", "minLength": 1 },
        "type": {
          "enum": [
            "string",
            "number",
            "boolean",
            "select",
            "string_list",
            "secret",
            "json"
          ]
        },
        "description": { "type": "string" },
        "required": { "type": "boolean" },
        "default": {},
        "options": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "minimum": { "type": "number" },
        "maximum": { "type": "number" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "secret" } },
            "required": ["type"]
          },
          "then": {
            "not": {
              "properties": { "default": {} },
              "required": ["default"]
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "select" } },
            "required": ["type"]
          },
          "then": {
            "properties": { "options": {} },
            "required": ["options"]
          }
        }
      ]
    }
  },
  "properties": {
    "id": { "$ref": "#/$defs/id" },
    "name": { "type": "string", "minLength": 1, "maxLength": 100 },
    "version": { "$ref": "#/$defs/version" },
    "description": { "type": "string", "minLength": 1, "maxLength": 500 },
    "apiVersion": { "const": "1.0" },
    "main": {
      "type": "string",
      "pattern": "^\\./dist/(?!.*(?:^|/)\\.\\.?/)[A-Za-z0-9._/-]+\\.js$"
    },
    "minimumOpsRabbitVersion": { "$ref": "#/$defs/version" },
    "publisher": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "pattern": "^https?://" }
      }
    },
    "requiredEntitlements": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]{0,79}$"
      }
    },
    "database": {
      "type": "object",
      "additionalProperties": false,
      "required": ["migrationsPath"],
      "properties": {
        "migrationsPath": {
          "type": "string",
          "pattern": "^\\./migrations/[a-z][a-z0-9_-]*$"
        }
      }
    },
    "dataInsight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["catalogRoute"],
      "properties": {
        "catalogRoute": {
          "type": "string",
          "pattern": "^/(?!.*(?:^|/)\\.\\.?/)[A-Za-z0-9._/-]+$"
        },
        "templatesRoute": {
          "type": "string",
          "pattern": "^/(?!.*(?:^|/)\\.\\.?/)[A-Za-z0-9._/-]+$"
        },
        "workspace": {
          "type": "object",
          "additionalProperties": false,
          "required": ["placement", "defaultTemplateId"],
          "properties": {
            "enabledSetting": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]{0,79}$"
            },
            "placement": { "const": "tab" },
            "defaultTemplateId": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_-]{0,79}$"
            },
            "defaultTab": { "enum": ["records", "insights"] },
            "allowUserDefault": { "type": "boolean" }
          }
        }
      }
    },
    "settings": {
      "type": "array",
      "items": { "$ref": "#/$defs/setting" },
      "uniqueItems": true
    },
    "navigation": { "$ref": "#/$defs/navigation" },
    "formStarterPack": { "$ref": "#/$defs/formStarterPack" },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "tools": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/tool" }
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/action" }
        },
        "scheduledJobs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/named" }
        },
        "routes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/route" }
        },
        "ingressRoutes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ingressRoute" }
        },
        "widgets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/named" }
        },
        "tenantRecords": {
          "type": "object",
          "additionalProperties": false,
          "required": ["collections"],
          "properties": {
            "collections": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
              }
            }
          }
        },
        "database": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode"],
          "properties": { "mode": { "const": "plugin_schema" } }
        },
        "objectStore": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "read": { "type": "boolean" },
            "write": { "type": "boolean" }
          }
        }
      }
    }
  },
  "dependentRequired": {
    "formStarterPack": ["navigation"],
    "database": ["capabilities"]
  },
  "allOf": [
    {
      "if": { "properties": { "database": {} }, "required": ["database"] },
      "then": {
        "properties": {
          "capabilities": {
            "type": "object",
            "properties": { "database": {} },
            "required": ["database"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "capabilities": {
            "type": "object",
            "properties": { "database": {} },
            "required": ["database"]
          }
        },
        "required": ["capabilities"]
      },
      "then": { "required": ["database"] }
    }
  ]
}
